{% extends 'base.html.twig' %}

{% block title %}Самая дорогая книга{% endblock %}

{% block body %}
<div class="container mt-5">
    <h1>💎 Самая дорогая книга</h1>
    <a href="{{ path('app_home') }}" class="btn btn-secondary mb-3">← На главную</a>
    
    <div class="card mt-4" style="max-width: 500px;">
        <div class="card-header bg-warning">
            <h3>Золотой том</h3>
        </div>
        <div class="card-body">
            <h5 class="card-title">{{ book.title }}</h5>
            <p class="card-text">
                <strong>Цена: {{ book.price }} руб.</strong>
            </p>
            
            {% if book.price > 2000 %}
                <div class="alert alert-danger mt-3">
                    ⚠️ Это очень дорогая книга! Стоит ее прорекламировать!
                </div>
            {% else %}
                <div class="alert alert-success mt-3">
                    ✅ Нормальная цена, не требует особой рекламы
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}